{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "nestquest-api",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 3000,
      "env": {
        "DATABASE_URL": "postgresql://localhost:5432/nestquest_v2"
      }
    },
    {
      "name": "nestquest-frontend",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["vite", "--port", "5173"],
