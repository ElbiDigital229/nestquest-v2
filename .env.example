# ── Required ────────────────────────────────────────────
DATABASE_URL=postgresql://localhost:5432/nestquest_v2
SESSION_SECRET=change-this-to-a-long-random-string-minimum-32-characters

# ── Environment ─────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ── CORS ────────────────────────────────────────────────
# Comma-separated list of allowed origins (REQUIRED in production)
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ── Cookies ─────────────────────────────────────────────
# Set to "true" if serving over HTTP (no SSL). Disables secure cookie flag.
# FORCE_INSECURE_COOKIES=true

# ── Stripe (Payment Gateway) ─────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Frontend uses the publishable key (add to Vite env as VITE_STRIPE_PUBLIC_KEY)
VITE_STRIPE_PUBLIC_KEY=pk_live_...

# ── Sentry (Error Tracking) ──────────────────────────────
SENTRY_DSN=https://...@sentry.io/...

# ── AWS S3 (File Storage + Backups) ─────────────────────
S3_BUCKET=nestquest-uploads
AWS_REGION=me-central-1
# Prefer IAM role on EC2 over hardcoded keys — leave blank if using IAM role
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# ── Redis (Session Store — enables horizontal scaling) ───
# Optional: falls back to PostgreSQL sessions if not set
# REDIS_URL=redis://localhost:6379
# For Redis with auth: redis://:password@host:6379

# ── Logging ─────────────────────────────────────────────
LOG_LEVEL=info

# ── API Docs ─────────────────────────────────────────────
# Swagger UI is auto-enabled in development.
# Set to "true" to expose in production (protect behind VPN or auth in prod).
# ENABLE_SWAGGER=true

# ── Backups ──────────────────────────────────────────────
# Number of days to retain S3 backups (default: 30)
# RETENTION_DAYS=30
# S3 key prefix for backups (default: db-backups)
# BACKUP_PREFIX=db-backups
